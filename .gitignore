# ============================================================================
# MAHOUN Platform - Security-Hardened .gitignore
# ============================================================================
# CLASSIFICATION: MISSION-CRITICAL / PUBLIC-RELEASE-READY
# PURPOSE: Prevent exposure of sensitive data, credentials, and proprietary logic
# ============================================================================

# ============================================================================
# CRITICAL SECURITY: CREDENTIALS & SECRETS (NEVER COMMIT)
# ============================================================================

# Environment files with secrets
.env
.env.*
!.env.example
!.env.backend.example
*.env
*.env.local
*.env.production
*.env.staging
*.env.development

# API Keys & Tokens
**/api_keys.txt
**/api_keys.json
**/*_api_key*
**/*_token*
**/*_secret*
**/*_password*
**/credentials.json
**/credentials.yaml
**/credentials.yml
**/auth_config.*
**/oauth_config.*

# SSH & Cryptographic Keys
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.cer
*.der
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
*.pub
!*.pub.example
secrets/
.secrets/
private/
.private/

