# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Git
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Python bytecode
*.pyc binary
*.pyo binary
*.pyd binary

# Archives
*.7z binary
*.jar binary
*.rar binary
*.tar.gz binary
*.tgz binary

# Exclude from exports
.github export-ignore
.vscode export-ignore
.idea export-ignore
tests/ export-ignore
docs/ export-ignore
*.md export-ignore
.gitignore export-ignore
.gitattributes export-ignore

# Linguist overrides (for GitHub language stats)
*.md linguist-documentation
*.txt linguist-documentation
docs/* linguist-documentation
tests/* linguist-vendored=false
ci/* linguist-vendored=false
scripts/* linguist-vendored=false

# Diff settings
*.py diff=python
*.md diff=markdown
*.json diff=json
*.yml diff=yaml
*.yaml diff=yaml

# Merge strategies
*.json merge=union
package-lock.json merge=ours
poetry.lock merge=ours
