# تنظیمات Production برای اتصال به سرور
# این فایل را قبل از build ویرایش کنید

# آدرس Backend روی سرور
# مثال: http://192.168.1.100:8000
# یا: http://your-domain.com
VITE_API_BASE_URL=http://YOUR_SERVER_IP:8000

# تنظیمات اضافی
VITE_APP_NAME=MAHOUN Platform
VITE_APP_VERSION=1.0.0
VITE_ENABLE_DEBUG=false
