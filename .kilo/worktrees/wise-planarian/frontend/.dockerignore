# ============================================================================
# MAHOUN Frontend - .dockerignore
# ============================================================================
# Exclude files from Docker build context for frontend builds
# ============================================================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs (will be regenerated)
dist/
dist-ssr/
*.local

# Testing
coverage/
.nyc_output/
test-results/

# IDE & Editor
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-*
.project
.settings/

# OS files
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
desktop.ini

# Environment files
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Git
.git/
.gitignore
.gitattributes

# Logs
*.log
logs/

# Misc
*.tsbuildinfo
.cache/

# Documentation
*.md
!README.md

# Docker
Dockerfile*
.dockerignore

# Storybook
storybook-static/

# TypeScript cache
*.tsbuildinfo

# Vite
.vite/

# ESLint
.eslintcache

