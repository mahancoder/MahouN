# ============================================================================
# MAHOUN Frontend - Environment Variables
# ============================================================================
# Copy this file to .env and update with your values
# ============================================================================

# Backend API URL
# Development: http://localhost:8000
# Production: Set to your actual backend URL or use Docker service name
VITE_API_URL=http://localhost:8000

# Note: Vite requires VITE_ prefix for env vars to be exposed to the client
# If not set, the app will fallback to http://localhost:8000
