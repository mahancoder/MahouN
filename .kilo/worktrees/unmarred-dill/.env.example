# ============================================================================
# MAHOUN Platform - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
MAHOUN_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json

# Version (for Docker images)
VERSION=latest

# ============================================================================
# Security - CRITICAL: Change these in production!
# ============================================================================
# Generate with: openssl rand -base64 32
SECURITY_JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32
API_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ============================================================================
# Database Passwords - CRITICAL: Change these in production!
# ============================================================================
# Generate with: openssl rand -base64 32
DB_NEO4J_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
DB_POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# ============================================================================
# Neo4j Configuration
# ============================================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_SIZE=2G
NEO4J_PAGECACHE_SIZE=1G
ENABLE_NEO4J=true

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mahoun
POSTGRES_USER=mahoun
POSTGRES_HOST_PORT=5432
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
ENABLE_POSTGRES=true

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PORT=6379
REDIS_MAX_MEMORY=2gb
ENABLE_REDIS=true

# ============================================================================
# ChromaDB Configuration
# ============================================================================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMADB_PORT=8001
CHROMA_TOKEN=
CHROMA_AUTH_PROVIDER=
CHROMA_TELEMETRY=FALSE

# ============================================================================
# Application Ports
# ============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443

# ============================================================================
# Worker Configuration
# ============================================================================
UNIFIED_LOADER_WORKERS=4
JOB_POLLING_INTERVAL=2
DLQ_MAX_RETRIES=3
MEMORY_SAFEGUARD_GB=2.0

# ============================================================================
# Monitoring Configuration
# ============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=http://localhost:8000
NODE_ENV=production

# ============================================================================
# Nginx Configuration (Frontend)
# ============================================================================
NGINX_WORKERS=auto
NGINX_CONNECTIONS=1024

# ============================================================================
# Guard Mode
# ============================================================================
# Options: OFF, WARN, STRICT, AUDIT
MAHOUN_GUARD_MODE=STRICT
