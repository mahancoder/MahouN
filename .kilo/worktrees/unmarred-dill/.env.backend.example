# ============================================================================
# MAHOUN Backend - Environment Configuration
# ============================================================================
# Zero-Hallucination AI Reasoning Platform
# Copy this file to .env and fill in the values
# ============================================================================

# ============================================================================
# SECURITY (REQUIRED - Generate with: make -f Makefile.backend generate-secrets)
# ============================================================================
SECURITY_JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================================================
# DATABASE PASSWORDS (REQUIRED)
# ============================================================================
DB_NEO4J_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
DB_POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment: development | staging | production
MAHOUN_ENV=production

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Guard Mode: OFF | WARN | STRICT | AUDIT
# STRICT = Zero-hallucination enforcement (RECOMMENDED for production)
MAHOUN_GUARD_MODE=STRICT

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
# Port
BACKEND_PORT=8000

# Workers & Performance
UNIFIED_LOADER_WORKERS=4
JOB_POLLING_INTERVAL=2
DLQ_MAX_RETRIES=3
MEMORY_SAFEGUARD_GB=2.0

# ============================================================================
# NEO4J - GRAPH DATABASE (CRITICAL)
# ============================================================================
# Connection
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# Password set above in DB_NEO4J_PASSWORD

# Ports (host machine)
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Memory Configuration (adjust based on your system)
# Recommended: heap = 1/4 of system RAM, pagecache = 1/2 of remaining RAM
NEO4J_HEAP_SIZE=4G
NEO4J_PAGECACHE_SIZE=2G

# ============================================================================
# POSTGRESQL - RELATIONAL DATABASE
# ============================================================================
# Connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mahoun
POSTGRES_USER=mahoun
# Password set above in DB_POSTGRES_PASSWORD

# Port (host machine)
POSTGRES_HOST_PORT=5432

# Memory Configuration
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=2GB
POSTGRES_MAINTENANCE_WORK_MEM=128MB

# ============================================================================
# REDIS - CACHE & DISTRIBUTED LOCKS
# ============================================================================
# Connection
REDIS_HOST=redis
REDIS_PORT=6379
# Password set above in REDIS_PASSWORD

# Port (host machine)
REDIS_HOST_PORT=6379

# Memory Configuration
REDIS_MAX_MEMORY=4gb

# ============================================================================
# CHROMADB - VECTOR STORE
# ============================================================================
# Connection
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_TOKEN=

# Port (host machine)
CHROMADB_PORT=8001

# Authentication (optional)
CHROMA_AUTH_PROVIDER=chromadb.auth.token.TokenAuthCredentialsProvider

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# ADVANCED CONFIGURATION (Optional)
# ============================================================================
# Version tag for images
VERSION=latest

# Timezone
TZ=UTC

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/Disable Services
ENABLE_NEO4J=true
ENABLE_POSTGRES=true
ENABLE_REDIS=true

# ============================================================================
# DEVELOPMENT ONLY (Not for production)
# ============================================================================
# Debug mode
# DEBUG=false

# Hot reload
# RELOAD=false

# ============================================================================
# NOTES
# ============================================================================
# 1. NEVER commit this file with real secrets to git!
# 2. Generate secrets with: make -f Makefile.backend generate-secrets
# 3. Use strong passwords (32+ characters, random)
# 4. Adjust memory settings based on your system resources
# 5. For production, use MAHOUN_GUARD_MODE=STRICT
# 6. Backup DB_NEO4J_PASSWORD and DB_POSTGRES_PASSWORD securely
# ============================================================================
